{
  "name": "@vafast/static",
  "version": "0.0.7",
  "description": "Plugin for Vafast for static file serving",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "tsdown",
    "dev": "npx tsx watch example/index.ts",
    "test": "npx vitest run",
    "release": "npm run build && npm run test && npx bumpp && npm publish --access=public",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "vafast": "<2.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^24.3.0",
    "rimraf": "^6.0.1",
    "tsdown": "^0.19.0-beta.4",
    "tsx": "^4.20.4",
    "typescript": "^5.4.5",
    "vitest": "^4.0.16",
    "vafast": "^0.8.1"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    }
  },
  "keywords": [
    "vafast",
    "static",
    "files"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/vafast/vafast-static"
  },
  "author": {
    "name": "saltyAom",
    "url": "https://github.com/SaltyAom",
    "email": "saltyaom@gmail.com"
  },
  "homepage": "https://github.com/vafast/vafast-static",
  "bugs": "https://github.com/vafast/vafast-static/issues",
  "dependencies": {
    "node-cache": "^5.1.2"
  }
}
